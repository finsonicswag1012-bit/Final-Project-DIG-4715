connectAttr "groupId15.msg" "blinn4SG.gn" -na;
connectAttr "pasted__groupId3.msg" "blinn4SG.gn" -na;
relationship "link" ":lightLinker1" ":initialShadingGroup.message" ":defaultLightSet.message";
